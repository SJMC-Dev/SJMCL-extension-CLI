import type { ExtensionFactory, ExtensionFactoryApi } from "./types/host";
import { ExtensionUISlotKey } from "./types/host";
import { createSaveInfoModal } from "./modals/save-info-modal";
import { createExamplePage } from "./pages/example-page";
import { createSettingsPage } from "./pages/settings-page";
import { createHomeExampleWidget } from "./widgets/home-example";
import { createHomeWelcomeWidget } from "./widgets/home-welcome";

(function registerExampleExtension(factory: ExtensionFactory) {
  const token = document.currentScript?.dataset?.extensionToken || "";

  if (!token) {
    throw new Error("Missing extension activation token");
  }

  if (typeof window.registerExtension !== "function") {
    throw new Error("SJMCL host is unavailable");
  }

  window.registerExtension(factory, token);
})(function createExtension(api: ExtensionFactoryApi) {
  const host = api.getHostContext();

  return {
    homeWidgets: [
      {
        key: "home-welcome",
        title: "Welcome!",
        description: "Example widget showing packaged static assets.",
        defaultWidth: 320,
        minWidth: 260,
        Component: createHomeWelcomeWidget(api),
      },
      {
        key: "home-example",
        title: "Home Example",
        description: __DESCRIPTION_JSON__,
        defaultWidth: 360,
        minWidth: 300,
        Component: createHomeExampleWidget(api),
      },
    ],
    settingsPage: {
      Component: createSettingsPage(api),
    },
    customModal: {
      key: "save-info",
      title: "SaveInfo",
      size: "xl",
      isCentered: true,
      scrollBehavior: "inside",
      Component: createSaveInfoModal(api),
    },
    pages: [
      {
        routePath: "example",
        Component: createExamplePage(api, false),
      },
      {
        routePath: "example-standalone",
        isStandAlone: true,
        Component: createExamplePage(api, true),
      },
    ],
    slots: {
      [ExtensionUISlotKey.InstanceWorldItemMenuOperations]: {
        getItems(context) {
          if (!context.instanceId || !context.save) {
            return [];
          }

          return [
            {
              icon: "info",
              label: "Show SaveInfo",
              onClick: () => {
                host.actions.openCustomModal("save-info", {
                  source: "world-slot",
                  instanceId: context.instanceId,
                  save: context.save,
                });
              },
            },
          ];
        },
      },
    },
  };
});
